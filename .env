APP_NAME="Phoenix IT"
APP_ENV=production
APP_KEY=base64:...
APP_DEBUG=false
APP_URL=https://phoenixitiq.com

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=phoenix_db
DB_USERNAME=phoenix_user
DB_PASSWORD=your_password

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

# البريد الإلكتروني
MAIL_MAILER=smtp
MAIL_HOST=mail.phoenixitiq.com
MAIL_PORT=587
MAIL_USERNAME=no-reply@phoenixitiq.com
MAIL_PASSWORD=secure_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@phoenixitiq.com
MAIL_FROM_NAME="${APP_NAME}"

# النسخ الاحتياطي
BACKUP_DISK=s3
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=phoenix-backups

# cPanel
CPANEL_HOST=https://phoenixitiq.com:2083
CPANEL_USERNAME=phoenix
CPANEL_TOKEN=your_token
CPANEL_API_URL=/execute

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Pusher للبث المباشر
PUSHER_APP_ID=your_app_id
PUSHER_APP_KEY=your_key
PUSHER_APP_SECRET=your_secret
PUSHER_APP_CLUSTER=mt1

# رقم إصدار النظام
APP_VERSION=1.0.0

# إعدادات النظام
ATTENDANCE_SYNC_INTERVAL=5
BACKUP_INTERVAL=1440
MAX_OVERTIME_HOURS=40

# إعدادات المزامنة
SYNC_ENABLED=true
SYNC_BACKUP_ENABLED=true
SYNC_NOTIFY_ADMIN=true

# إعدادات IP API
IP_API_KEY=your_api_key